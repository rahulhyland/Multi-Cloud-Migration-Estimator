# Copy this file to .env and fill in your tokens.
# .env is gitignored and will NOT be committed.

# GitHub API Token (for remote Terraform repo discovery)
# Create a PAT at: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# Atlassian Confluence API (for publishing migration reports)
ATLASSIAN_API_EMAIL=your_email@company.com
ATLASSIAN_API_TOKEN=your_confluence_api_token_here
ATLASSIAN_API_ENDPOINT=https://hyland.atlassian.net
ATLASSIAN_DOMAIN=hyland.atlassian.net
ATLASSIAN_SPACE_KEY=MigrationT
